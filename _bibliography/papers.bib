  selected={true}
}

@article{davidson2025superalgebra,
  title={Superalgebra deformations of web categories: Affine and cyclotomic webs},
  author={Davidson, Nicholas and Kujawa, Jonathan R. and Muth, Robert},
  year={2025},
  eprint={2511.21671},
  archivePrefix={arXiv},
  primaryClass={math.RT},
  abstract={We introduce a diagrammatic monoidal supercategory associated with locally unital Frobenius superalgebras as an affinization of the finite web category previously defined by the authors and Zhu. We establish functorial connections to module categories and provide a basis for morphism spaces using decorated double coset diagrams. We further extend results to cyclotomic quotient categories with associated basis theorems.},
  html={https://arxiv.org/abs/2511.21671},
  selected={true}
}
